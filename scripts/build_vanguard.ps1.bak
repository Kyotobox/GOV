# SCRIPT DE CONSTRUCCIÓN Y DESPLIEGUE EN CASCADA (v9.0.1) [DPI-GATE-GOLD]
$ProjectRoot = "c:\Users\Ruben\Documents\antigravity_dpi"
$BunkerPath = "$ProjectRoot\vanguard_agent"

# Flota de Destino
$Destinations = @(
    "c:\Users\Ruben\Documents\Base2\bin",
    "c:\Users\Ruben\Documents\miniduo"
)

Write-Host "=== [GOV] INICIANDO COMPILACIÓN DUAL v9.0.1 (CASCADE) ===" -ForegroundColor Cyan

# 1. Compilación del Kernel (antigravity_dpi)
Write-Host "Compilando Kernel (gov.dart)..." -ForegroundColor Yellow
Push-Location $ProjectRoot
dart compile exe bin/antigravity_dpi.dart -o bin/gov.exe
if ($LASTEXITCODE -ne 0) { Write-Host "[FAIL] Error en Kernel." -ForegroundColor Red; exit 1 }

# S30-REV: Generación de Sello de Relevo (Sign)
Write-Host "Firmando binario para cascada..." -ForegroundColor Cyan
.\bin\gov.exe sign --file bin\gov.exe
Pop-Location

# 2. Compilación del Agente (Vanguard)
if (-not (Test-Path $BunkerPath)) {
    Write-Host "[ERROR] No se encuentra el búnker: $BunkerPath" -ForegroundColor Red
    exit 1
}

Push-Location $BunkerPath
Write-Host "Limpiando y preparando entorno Agente..." -ForegroundColor Yellow
flutter clean
flutter pub get

Write-Host "Compilando Vanguard Agent (Release)..." -ForegroundColor Yellow
flutter build windows --release

$BinaryPath = "$BunkerPath\build\windows\x64\runner\Release\vanguard_agent.exe"

    if (Test-Path $BinaryPath) {
        Write-Host "[OK] Compilación exitosa del Agente." -ForegroundColor Green
        
        foreach ($DestPath in $Destinations) {
            # S30-REV: Replicación de Relevo (Autonomía Local)
            $TargetBin = Join-Path $DestPath "bin"
            if (-not (Test-Path $TargetBin)) { New-Item -ItemType Directory -Path $TargetBin -Force }
            $TargetVault = Join-Path $DestPath "vault"
            if (-not (Test-Path $TargetVault)) { New-Item -ItemType Directory -Path $TargetVault -Force }

            Write-Host "Replicando Binario y Sello en: $DestPath ..." -ForegroundColor Cyan
            Copy-Item "$ProjectRoot\bin\gov.exe" -Destination "$TargetBin\gov.exe.update" -Force
            Copy-Item "$ProjectRoot\bin\gov.exe.sig" -Destination "$TargetBin\kernel_handover.sig" -Force
            Copy-Item "$ProjectRoot\vault\po_public.xml" -Destination "$TargetVault\po_public.xml" -Force
            
            Copy-Item $BinaryPath -Destination "$TargetBin\vanguard.exe" -Force
            
            # DLLs y Dependencias
            Get-ChildItem "$BunkerPath\build\windows\x64\runner\Release\*.dll" | ForEach-Object {
                Copy-Item $_.FullName -Destination $TargetBin -Force
            }
            Write-Host "[SUCCESS] Cascada de Relevo completada para $DestPath" -ForegroundColor Green
        }
        
        Write-Host "[FINAL] Propagación v9.0.1 finalizada con éxito." -ForegroundColor Cyan
    } else {
        Write-Host "[FAIL] Error crítico en la compilación del Agente." -ForegroundColor Red
    }

Pop-Location
Write-Host "=== [GOV] FIN DEL PROCEDIMIENTO DE CASCADA ===" -ForegroundColor Cyan
